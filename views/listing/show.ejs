<% layout("/layouts/boilerplate")%>
    <h3 class="text-center">Details:</h3>
    <div class=" d-flex gap-4" style="width: 100%;height: 75%;">
        <div><img src="<%=listing.image %>" class="card-img-top" alt="listing-image" style=" height: 75%;"></div>
        <div class="card-body">
            <div class="lists">
                <ul>
                    <li><b><%= listing.title %></b></li>
                    <li><%= listing.description %></li>
                    <li>&#8377;<%= listing.price.toLocaleString("en-IN") %>/Night</li>
                    <li><%= listing.location %></li>
                    <li><%= listing.country %></li>
                </ul>
                <div>
                    <div class="d-flex ms-2 gap-2">
                        <form action="/listing/<%=listing._id%>/edit">
                            <button class=" btn border-black card-link">Edit</button>
                        </form>
                        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                            <button class=" btn border-black card-link">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>